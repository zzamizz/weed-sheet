SR "[Put Down the Popcorn\Enable Mod]"

Set CurrentMap 0x3E1110
Set LoadingState 0x3D3980

// Technical notes:

// A delay of zero can be used to stabilize broken scripts. For example, the ending cutscene of
// Steal a Tuxedo consists of a single voice line instruction and nothing else. If you skip the voice
// line, the script finishes but the job doesn't end, leaving you softlocked. If you instead replace
// the voice line instruction with a delay instruction which uses a duration of zero, the cutscene is
// skipped and the job ends properly. It seems this is the dev-intended solution, as there's dozens if
// not hundreds of delays of zero across all the game's scripts.

// Most modified scripts were present in mapname_macro or mapname_rig, however plenty of job-specific
// scripts appear in the other mapname_ entities, such as a cutscene related to interacting with the
// satellite at the end of Cabin Crimes being stored in mapname_recon_ext.

// The ending cutscene of Satellite Sabotage is a timed zoom-out with data stored in a special entity.
// A pointer exists for it, but it changes contents while loading, probably as a list fills up.
// An If Not Loading check is required.

// A global pointer to the first photo op target exists at 0x3E06F0, and you can use
// the Next Same Entity pointer to reach the next one. This also needs an If Not Loading check.

// Similar to recon photo target structs, there's a pointer to the first camera struct in each map
// at 0x3E06D8, and you can reach each one with the Next Same Entity pointer, also making sure to
// put the entire thing under an If Not Loading check. This is the only way to reach the cameras used
// during Disco Demolitions.

// 0x45209C appears to be a part of some global region that changes a lot during gameplay,
// but that exact pointer doesn't change. It leads to the start of a long region of Splice code, some
// of this code being copied to a temporary Splice code region elsewhere, that region only
// existing during use, otherwise it's populated by a different struct.

// Cairo

If CurrentMap =. 0x0

    WritePointer32 0x488590,0x0,0x2100 0xFFFFFFFF
    WritePointer32 0x488590,0x0,0x2150 0xFFFFFFFF
    WritePointer32 0x488590,0x0,0x21B0 0xFFFFFFFF
    WritePointer32 0x488590,0x0,0x2200 0xFFFFFFFF
    WritePointer32 0x488590,0x0,0x2250 0xFFFFFFFF
    WritePointer32 0x488590,0x0,0x22A0 0xFFFFFFFF
    WritePointer32 0x488590,0x0,0x22F0 0xFFFFFFFF
    WritePointer32 0x488590,0x0,0x2330 0xFFFFFFFF
    WritePointer32 0x488590,0x0,0x2390 0xFFFFFFFF
    WritePointer32 0x488590,0x0,0x23D0 0xFFFFFFFF
    WritePointer32 0x488590,0x0,0x2430 0xFFFFFFFF
    WritePointer32 0x488590,0x0,0x24D0 0x0
    WritePointer32 0x488590,0x0,0x2510 0xFFFFFFFF
    WritePointer32 0x488590,0x0,0x2610 0x0
